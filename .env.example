# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/llm_monitor
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/llm_monitor

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Auth ─────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ─── LLM (for compression agent) ──────────────────────────────
OPENAI_API_KEY=sk-...
COMPRESSION_MODEL=gpt-4o-mini

# ─── Notifications ────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── SDK (used by dashboard/test) ─────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
